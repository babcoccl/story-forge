# StoryForge Environment Configuration
# Copy this file to .env and adjust values.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/storyforge

# LLM / llama.cpp (OpenAI-compatible HTTP server)
LLM_BASE_URL=http://127.0.0.1:8080/v1
DEFAULT_MODEL=qwen3-27b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.8

# Pipeline
MAX_COMBINATION_RETRIES=5