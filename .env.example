# Copy to .env and fill in values before running
DATABASE_URL=postgresql+asyncpg://storyforge:change_me_now@localhost:5432/storyforge
DATABASE_URL_SYNC=postgresql+psycopg2://storyforge:change_me_now@localhost:5432/storyforge

# llama.cpp server endpoint (OpenAI-compatible)
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=local

# The model name as reported by your llama.cpp server
DEFAULT_MODEL=unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q4_K_XL

# Generation settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.8
LLM_CONTEXT_WINDOW=32768
LLM_TIMEOUT=120.0

# Story generation
MAX_SCENE_RETRIES=3
MAX_COMBINATION_RETRIES=5
# Minimum floor for computed per-scene word count (not a cap)
# Actual target is computed as target_word_count / total_scenes
MIN_WORDS_PER_SCENE=800

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO